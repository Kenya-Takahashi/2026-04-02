{
  email {$LETSENCRYPT_EMAIL}
}

{$APP_DOMAIN} {
  encode zstd gzip

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "SAMEORIGIN"
  }

  @research_flow path {$APP_BASE_PATH} {$APP_BASE_PATH}/*

  handle @research_flow {
    reverse_proxy app:3000
  }

  # Replace this fallback block if appkenya.com already has another site upstream.
  # Example:
  # handle {
  #   reverse_proxy existing-main-site:8080
  # }
  handle {
    respond "Configure your main appkenya.com site here." 404
  }
}
